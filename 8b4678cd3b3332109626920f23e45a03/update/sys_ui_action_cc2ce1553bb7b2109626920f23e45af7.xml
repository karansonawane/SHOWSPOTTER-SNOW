        <script><![CDATA[// This function runs on the Client (Browser)
function confirmDeleteRecord() {
    var confirmMsg = "Are you sure you want to remove this from your watchlist? This action cannot be undone.";

    if (confirm(confirmMsg)) {
        // If the user clicks 'OK', call the server-side function
        gsftSubmit(null, g_form.getFormElement(), 'remove_from_watchlist_btn');
    } else {
        // If the user clicks 'Cancel', do nothing
        return false;
    }
}

// This part runs on the Server (Database)
if (typeof window == 'undefined') {
    runServerCode();
}

function runServerCode() {
    var grMyWatchList = new GlideRecord('x_1962882_show_s_0_my_watchlist');
    grMyWatchList.addQuery('id', current.id);
    grMyWatchList.query();

    if (grMyWatchList.next()) {
        grMyWatchList.deleteRecord();
        gs.addInfoMessage('Removed from your watchlist.');
    } else {
        gs.addErrorMessage('Record not found in watchlist.');
    }

    action.setRedirectURL(current);
}]]></script>
