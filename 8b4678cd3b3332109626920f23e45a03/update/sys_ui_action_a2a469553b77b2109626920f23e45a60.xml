        <name>Add to Watchlist</name>
        <onclick/>
        <order>100</order>
        <script><![CDATA[var grMyWatchListChecks = new GlideRecord('x_1962882_show_s_0_my_watchlist');
grMyWatchListChecks.addQuery('id', current.id);
grMyWatchListChecks.query();
if (grMyWatchListChecks.next()) {
    gs.addErrorMessage(current.name + '" is already in your watchlist.');
} else {
    var grMyWatchList = new GlideRecord('x_1962882_show_s_0_my_watchlist');

    grMyWatchList.initialize();
    grMyWatchList.name = current.name;
    grMyWatchList.genres = current.genres,
        grMyWatchList.id = current.id,
        grMyWatchList.imdb_id = current.imdb_id || "",
        grMyWatchList.overview = current.overview,
        grMyWatchList.release_date = current.release_date,
        grMyWatchList.poster = current.poster,
		grMyWatchList.rating = current.rating

    var sysId = grMyWatchList.insert();

    if (sysId) {
        gs.addInfoMessage('Success! "' + current.name + '" has been added to your watchlist.');
    } else {
        gs.addErrorMessage('Something went wrong while saving the movie.');
    }
}

action.setRedirectURL(current);]]></script>
